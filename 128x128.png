[package]
name = "fabify"
version = "1.0.0"
description = "Fabify Desktop App"
edition = "2021"

[build-dependencies]
tauri-build = { version = "2", features = [] }

[dependencies]
tauri = { version = "2", features = [] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"

[[bin]]
name = "fabify"
path = "src/main.rs"
